{%- liquid
  assign cx_icon_size = size | default: 20
  assign cx_icon_class = 'cx-icon'
  if class != blank
    assign cx_icon_class = cx_icon_class | append: ' ' | append: class
  endif
-%}
{%- case icon -%}
{%- when 'lock' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="3.5" y="8.5" width="13" height="9" rx="2"/><path d="M6.5 8.5V6a3.5 3.5 0 0 1 7 0v2.5"/><circle cx="10" cy="13" r="1.25" fill="currentColor" stroke="none"/></svg>
{%- when 'truck' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M1.5 4.5h10v9h-10z"/><path d="M11.5 7.5h3.2l3.3 3.3v2.7h-6.5"/><circle cx="5.5" cy="15" r="1.75"/><circle cx="14.5" cy="15" r="1.75"/></svg>
{%- when 'box' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m10 2.2 7 3.5v8.6l-7 3.5-7-3.5V5.7z"/><path d="M3 5.7l7 3.5 7-3.5"/><path d="M10 9.2v8.6"/><path d="m6.5 3.95 7 3.5"/></svg>
{%- when 'shield-check' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10 1.8 3.5 4.2v5c0 4.2 2.8 7.3 6.5 8.9 3.7-1.6 6.5-4.7 6.5-8.9v-5z"/><path d="m7 9.8 2.2 2.2L13.2 8"/></svg>
{%- when 'leaf' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M16.8 3.2c.3 6.8-2.6 12.4-8.4 12.4-2.3 0-4.2-1.4-4.9-3.3C5 8 9.6 3.9 16.8 3.2Z"/><path d="M3.5 16.5C6 12.5 9.5 9.5 13 7.7"/></svg>
{%- when 'star' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="currentColor" stroke="none" aria-hidden="true" focusable="false"><path d="M10 1.6l2.6 5.3 5.8.8-4.2 4.1 1 5.8-5.2-2.7-5.2 2.7 1-5.8L1.6 7.7l5.8-.8z"/></svg>
{%- when 'star-half' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M10 1.6l2.6 5.3 5.8.8-4.2 4.1 1 5.8-5.2-2.7-5.2 2.7 1-5.8L1.6 7.7l5.8-.8z" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M10 1.6v12.5l-5.2 2.7 1-5.8L1.6 7.7l5.8-.8z" fill="currentColor"/></svg>
{%- when 'droplet' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10 2.2S4.6 8 4.6 12a5.4 5.4 0 0 0 10.8 0c0-4-5.4-9.8-5.4-9.8Z"/><path d="M7.4 12.4a2.6 2.6 0 0 0 2.1 2.5"/></svg>
{%- when 'check' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m3.5 10.5 4.2 4.2 8.8-9.4"/></svg>
{%- when 'refresh' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M16.5 8A6.8 6.8 0 0 0 4.2 6.2L2.8 7.9"/><path d="M2.8 3.9v4h4"/><path d="M3.5 12a6.8 6.8 0 0 0 12.3 1.8l1.4-1.7"/><path d="M17.2 16.1v-4h-4"/></svg>
{%- when 'seal-check' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="10" cy="8" r="4.6"/><path d="m8.1 8.1 1.4 1.4 2.4-2.8"/><path d="M4.6 11.4c-1.2 1.4-1.8 3.2-1.7 5 1.7 0 3.3-.7 4.6-1.9"/><path d="M15.4 11.4c1.2 1.4 1.8 3.2 1.7 5-1.7 0-3.3-.7-4.6-1.9"/><path d="m6.2 14.7.9 1"/><path d="m13.8 14.7-.9 1"/></svg>
{%- when 'bottle' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="7.8" y="1.8" width="4.4" height="2.6" rx="0.8"/><path d="M8.6 4.4v1.8M11.4 4.4v1.8"/><path d="M8.6 6.2h2.8c1.7.5 2.8 2 2.8 3.9v5.7a2.2 2.2 0 0 1-2.2 2.2H8a2.2 2.2 0 0 1-2.2-2.2v-5.7c0-1.9 1.1-3.4 2.8-3.9Z"/><path d="M5.8 12.4h8.4"/></svg>
{%- when 'download' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10 2.8v9.4"/><path d="m6.4 8.8 3.6 3.6 3.6-3.6"/><path d="M3.5 16.8h13"/></svg>
{%- when 'question' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="10" cy="10" r="7.5"/><path d="M7.8 7.8a2.2 2.2 0 1 1 3.1 2.4c-.7.3-.9.8-.9 1.5"/><circle cx="10" cy="14.1" r="0.9" fill="currentColor" stroke="none"/></svg>
{%- when 'calendar' -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2.8" y="4.2" width="14.4" height="13" rx="2"/><path d="M2.8 8.4h14.4"/><path d="M6.8 2.2v3.6M13.2 2.2v3.6"/></svg>
{%- else -%}
<svg class="{{ cx_icon_class }}" width="{{ cx_icon_size }}" height="{{ cx_icon_size }}" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="10" cy="10" r="7.5"/><path d="m7 10 2.2 2.2L13.2 8"/></svg>
{%- endcase -%}
